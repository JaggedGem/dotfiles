{
  "systemCmd": "checkupdates 2>/dev/null",
  "aurCmd": "yay -Qua 2>/dev/null",
  "updateCmd": "ghostty -e bash -c 'echo \"Updating System...\";yay; read -n 1 -p \"Press any key to exit...\"'",
  "aurHomepageCmd": "yay -Si {id} 2>/dev/null | awk 'FNR == 5 {print $3}'",
  "flatpak": false,
  "noctalia": true,
  "toast": false,
  "desktopTip": true,
  "hideOnEmpty": false,
  "refreshTimer": true,
  "refreshInterval": 120,
  "iconName": "arrow-big-down-lines",
  "useDistroLogo": false,
  "customIconPath": "",
  "boldText": true,
  "enableColorization": false,
  "iconColor": "none",
  "boldVer": true,
  "tooltip": true,
  "closeButton": true,
  "closeOnSettings": false,
  "panelTooltip": true,
  "panelContext": true,
  "boldVerPanel": true,
  "boldVerDesktop": true,
  "hoverTip": true
}
